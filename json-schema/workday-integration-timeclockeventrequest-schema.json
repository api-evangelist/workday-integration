{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TimeClockEventRequest",
  "title": "TimeClockEventRequest",
  "type": "object",
  "required": [
    "worker",
    "eventType",
    "eventDateTime"
  ],
  "properties": {
    "worker": {
      "$ref": "#/components/schemas/ResourceReference"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "Clock_In",
        "Clock_Out"
      ]
    },
    "eventDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "timeZone": {
      "type": "string"
    }
  }
}