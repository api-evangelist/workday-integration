          },
          "descriptor": {
            "type": "string"
          },
          "worker": {
            "$ref": "#/components/schemas/ResourceReference"
          },
          "severity": {
            "type": "string",
            "enum": [
              "Error",
              "Warning"
            ]
          },
          "message": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}