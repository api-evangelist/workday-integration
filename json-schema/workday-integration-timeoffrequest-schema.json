{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TimeOffRequest",
  "title": "TimeOffRequest",
  "type": "object",
  "required": [
    "absenceType",
    "days"
  ],
  "properties": {
    "absenceType": {
      "$ref": "#/components/schemas/ResourceReference"
    },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "quantity"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "quantity": {
            "type": "number"
          },
          "comment": {
            "type": "string"
          }
        }
      }
    }
  }
}