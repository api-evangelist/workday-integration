{
  "opencollection": "1.0.0",
  "info": {
    "name": "Workday Integration Workday Cash Management API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://{baseUrl}/authorize",
      "accessTokenUrl": "https://{baseUrl}/oauth2/{tenant}/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Bank Accounts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve bank accounts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/cashManagement/v1/{tenant}/bankAccounts",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a collection of bank accounts configured in the tenant."
        },
        {
          "info": {
            "name": "Workday Integration Retrieve a specific bank account",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/cashManagement/v1/{tenant}/bankAccounts/:ID",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns the specified bank account with its details and balances."
        }
      ]
    },
    {
      "info": {
        "name": "Bank Statements",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve bank statements",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/cashManagement/v1/{tenant}/bankStatements",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a collection of bank statement records."
        }
      ]
    },
    {
      "info": {
        "name": "Cash Positions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve cash positions",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/cashManagement/v1/{tenant}/cashPositions",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a collection of cash positions across bank accounts."
        }
      ]
    }
  ],
  "bundled": true
}