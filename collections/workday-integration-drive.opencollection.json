{
  "opencollection": "1.0.0",
  "info": {
    "name": "Workday Integration Workday Drive API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://{baseUrl}/authorize",
      "accessTokenUrl": "https://{baseUrl}/oauth2/{tenant}/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Drive",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve a collection of files",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/drive/v1/{tenant}/files",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "search",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a collection of files from the Workday Drive API."
        },
        {
          "info": {
            "name": "Workday Integration Retrieve a specific File",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/drive/v1/{tenant}/files/:ID",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns the specified File instance with its details."
        }
      ]
    }
  ],
  "bundled": true
}