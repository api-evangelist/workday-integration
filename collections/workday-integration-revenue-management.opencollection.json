{
  "opencollection": "1.0.0",
  "info": {
    "name": "Workday Integration Workday Revenue Management API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://{baseUrl}/authorize",
      "accessTokenUrl": "https://{baseUrl}/oauth2/{tenant}/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Revenue Schedules",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve revenue schedules",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/revenueManagement/v1/{tenant}/revenueSchedules",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a collection of revenue recognition schedules."
        }
      ]
    },
    {
      "info": {
        "name": "Contracts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve revenue contracts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/revenueManagement/v1/{tenant}/contracts",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "search",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a collection of revenue contracts."
        },
        {
          "info": {
            "name": "Workday Integration Retrieve a specific revenue contract",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/revenueManagement/v1/{tenant}/contracts/:ID",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns the specified revenue contract with its details."
        }
      ]
    }
  ],
  "bundled": true
}