{
  "opencollection": "1.0.0",
  "info": {
    "name": "Workday Integration Workday Learning API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://{baseUrl}/authorize",
      "accessTokenUrl": "https://{baseUrl}/oauth2/{tenant}/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Courses",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve learning courses",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/learning/v1/{tenant}/learningCourses",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "search",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a collection of learning courses available in the catalog."
        },
        {
          "info": {
            "name": "Workday Integration Retrieve a specific learning course",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/learning/v1/{tenant}/learningCourses/:ID",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns the specified learning course with its content and configuration."
        }
      ]
    },
    {
      "info": {
        "name": "Assignments",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve learning assignments for a worker",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/learning/v1/{tenant}/workers/:ID/learningAssignments",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns the learning assignments for the specified worker."
        }
      ]
    },
    {
      "info": {
        "name": "Completions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve learning completions for a worker",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/learning/v1/{tenant}/workers/:ID/learningCompletions",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns the learning completion records for the specified worker."
        }
      ]
    }
  ],
  "bundled": true
}