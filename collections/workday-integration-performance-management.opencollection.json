{
  "opencollection": "1.0.0",
  "info": {
    "name": "Workday Integration Workday Performance Management API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://{baseUrl}/authorize",
      "accessTokenUrl": "https://{baseUrl}/oauth2/{tenant}/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Feedback",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve feedback badges",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/performanceManagement/v1/{tenant}/feedbackBadges",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns the available feedback badges that can be awarded to workers."
        },
        {
          "info": {
            "name": "Workday Integration Retrieve a specific feedback badge",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/performanceManagement/v1/{tenant}/feedbackBadges/:ID",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns the specified feedback badge with its details."
        }
      ]
    },
    {
      "info": {
        "name": "Goals",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve goals for a worker",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/performanceManagement/v1/{tenant}/workers/:ID/goals",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns the performance goals for the specified worker."
        }
      ]
    },
    {
      "info": {
        "name": "Performance Reviews",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Integration Retrieve performance reviews for a worker",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{baseUrl}/ccx/api/performanceManagement/v1/{tenant}/workers/:ID/performanceReviews",
            "params": [
              {
                "name": "ID",
                "value": "",
                "type": "path"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns the performance review records for the specified worker."
        }
      ]
    }
  ],
  "bundled": true
}